# Database connection (Supabase or local PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/mnemo

# Anthropic (for Claude chat)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: custom API base URL for third-party providers (e.g., proxy)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional: override default chat model ID
# ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# OpenAI (for embedding generation, Phase 3+)
OPENAI_API_KEY=sk-...
# Optional: custom API base URL for third-party providers
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: override default chat model ID (used when ANTHROPIC is not configured)
# OPENAI_CHAT_MODEL_ID=gpt-4o
# Optional: override default embedding model ID
# OPENAI_EMBEDDING_MODEL_ID=text-embedding-3-small

# Hardcoded user ID for demo (no auth system)
DEFAULT_USER_ID=demo-user
