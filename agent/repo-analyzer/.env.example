# === LLM 模型配置 ===
# 模型提供商：openai 或 anthropic
MODEL_PROVIDER=anthropic
# 模型名称：如 gpt-4o、claude-sonnet-4-6
MODEL_NAME=claude-sonnet-4-6

# === API 中转站地址（可选）===
# 使用中转站/代理服务时取消注释并填入地址，不使用时保持注释状态
# MODEL_BASE_URL=https://your-proxy.example.com/v1

# === API Key（根据 MODEL_PROVIDER 配置对应的 Key）===
# OpenAI API Key，从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-key-here
# Anthropic API Key，从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === GitHub 配置（可选）===
# GitHub Personal Access Token，用于提升 API 速率限制（无 Token: 60次/小时，有 Token: 5000次/小时）
# 从 https://github.com/settings/tokens 创建
GITHUB_TOKEN=
